# Cinder environment configuration
#
# Frontend (Vite) public vars must be prefixed with VITE_.
# Optional: show an "Install the app" IPA prompt on the invite page when set.
VITE_IPA_DOWNLOAD_URL=
# Optional: enable Cloudflare Web Analytics by providing a token.
VITE_CF_ANALYTICS_TOKEN=

# --- Server-side (configure as Pages / Worker secrets, NOT committed) ---
# Used to sign one-time upload tokens for R2. Generate a long random value.
# wrangler pages secret put UPLOAD_SECRET
UPLOAD_SECRET=
